<% layout("/layouts/boilerplate") %>
<body>
  <div class="row">
    <div class="col-8 offset-2">
  <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class=" needs-validation" enctype="multipart/form-data">
    <br><br>
  <h3>Edit Your Listing Listing</h3>
  <br><br>
    <div class="mb-3">
      <label for="name" class="form-label">Title : </label>
       <input id="name" type="text" name="listing[title]" required="true" value= "<%= listing.title %>"class="form-control">
       <div class="valid-feedback">Title Looks good!</div>
    </div>
    <div class="mb-3">
      <label for="descripton" class="form-label">Description : </label>
      <textarea name="listing[dscrpt]" id="descripton" class="form-control"> <%= listing.dscrpt %> </textarea>
    </div>

    <div class="mb-3">
      Original Image :
      <img src="<%= originalImg %>">
    </div>

    <div class="mb-3">
      <label for="Image" class="form-label">Upload New Image  : </label>
      <input id="Image" type="file" name="listing[img]" class="form-control">
    </div>

    <div class="row">
      <div class="mb-3 col-md-4">
        <label for="Price" class="form-label">Price : </label>
        <input id="Price" type="number" name="listing[price]" required="true" value=<%= listing.price %> class="form-control">
        <div class="invalid-feedback">Price Should be valid</div>
      </div>

      <div class="mb-3 col-md-8">
        <label for="country" class="form-label" >Country: </label>
      <input id="country" type="text" name="listing[country]" required="true"  value=<%= listing.country %> class="form-control">
      <div class="invalid-feedback">The Country name Should be valid</div>
      </div>
      
    </div>
    
    
    
    <div class="mb-3">
      <label for="location" class="form-label">Location : </label>
      <input id="location" type="text" name="listing[location]" required="true" value="<%= listing.location %>" class="form-control">
      <div class="invalid-feedback"> Location Should be valid</div>
    </div>

    <div class="mb-3" style="display: flex;">
      <label class="form-label">Select Category:</label>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" value="rooms" id="rooms"
        <% if(listing.category.includes("rooms")){ %> checked <%} %>>
        <label class="form-check-label" for="rooms">Rooms</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" value="iconic_city" id="iconic_city" <% if(listing.category.includes("iconic_city")){ %> checked <%} %>>
        <label class="form-check-label" for="iconic_city">Iconic City</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" value="mountain" id="mountain" <% if(listing.category.includes("mountain")){ %> checked <%}%>>
        <label class="form-check-label" for="mountain">Mountain</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" value="castles" id="castles" <% if(listing.category.includes("castles")){ %> checked <%} %>>
        <label class="form-check-label" for="castles">Castles</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" value="pools" id="pools" <% if(listing.category.includes("pools")){ %> checked <%} %>>
        <label class="form-check-label" for="pools">Pools</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" value="camps" id="camps" <% if(listing.category.includes("camps")){ %> checked <%} %>>
        <label class="form-check-label" for="camps">Camps</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" value="farms" id="farms" <% if(listing.category.includes("farms")) { %> checked <%} %>>
        <label class="form-check-label" for="farms">Farms</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="checkbox" name="listing[category][]" value="arctic" id="arctic" <% if(listing.category.includes("arctic")){ %> checked <%} %>>
        <label class="form-check-label" for="arctic">Arctic</label>
      </div>
    </div>
    
    <br><br>
    
    <button class="btn btn-dark add-btn">Edit Listing</button>
  </form>
  <br>
  <br>
</div>
</div>
 
</body>

<style>
  .form-check {
    margin-left: 15px;
  }
</style>